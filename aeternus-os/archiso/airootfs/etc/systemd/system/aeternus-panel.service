[Unit]
Description=Aeternus OS Desktop Panel (X11/Cairo)
Documentation=file:///usr/local/src/aeternus-gui/panel/aeternus-panel.c
After=graphical.target

[Service]
Type=simple
Environment=DISPLAY=:0
ExecStartPre=/bin/sleep 2
ExecStart=/usr/local/bin/aeternus-panel
Restart=on-failure
RestartSec=3s

[Install]
WantedBy=graphical.target
