# V0rtexOS — Tor Configuration (hardened)
# /etc/tor/torrc — Ghost Protocol Engine

# ══════════════════════════════════════════════════════════
# PORTAS PRINCIPAIS
# ══════════════════════════════════════════════════════════
SocksPort 9050
SocksPort 9051 IsolateDestAddr IsolateDestPort
SocksPolicy accept 127.0.0.1
SocksPolicy accept 10.0.0.0/8
SocksPolicy reject *

ControlPort 9053
ControlListenAddress 127.0.0.1
HashedControlPassword ""
CookieAuthentication 1
CookieAuthFileGroupReadable 1

# ══════════════════════════════════════════════════════════
# TRANSPARENTE (redirecionar TODO tráfego via Tor)
# ══════════════════════════════════════════════════════════
TransPort 9040 IsolateClientAddr IsolateClientProtocol IsolateDestAddr IsolateDestPort
TransListenAddress 127.0.0.1
TransPort [::1]:9040

# ══════════════════════════════════════════════════════════
# DNS VIA TOR
# ══════════════════════════════════════════════════════════
DNSPort 5353
DNSListenAddress 127.0.0.1
AutomapHostsOnResolve 1
AutomapHostsSuffixes .exit,.onion,.onion.

# ══════════════════════════════════════════════════════════
# PRIVACIDADE / LOGGING
# ══════════════════════════════════════════════════════════
Log notice syslog
Log warn file /var/log/tor/warnings.log
SafeLogging 1
LogTimeGranularity 60

# ══════════════════════════════════════════════════════════
# SEGURANÇA DO PROCESSO
# ══════════════════════════════════════════════════════════
DataDirectory /var/lib/tor
DisableAllSwap 1
HardwareAccel 1
AvoidDiskWrites 1
NoExec 1

# ══════════════════════════════════════════════════════════
# CIRCUITOS — OTIMIZAÇÕES
# ══════════════════════════════════════════════════════════
MaxCircuitDirtiness 300
NewCircuitPeriod 30
CircuitBuildTimeout 10
LearnCircuitBuildTimeout 0
MaxClientCircuitsPending 48
CircuitStreamTimeout 60
EnforceDistinctSubnets 1

# ══════════════════════════════════════════════════════════
# NÓS DE SAÍDA — EXCLUIR FIVE EYES + ALIADOS
# ══════════════════════════════════════════════════════════
ExcludeExitNodes {us},{gb},{au},{ca},{nz},{de},{fr},{nl},{be},{se},{no},{dk},{fi},{it},{es},{jp},{kr},{sg},{il},{tr}
ExcludeNodes {us},{gb},{au},{ca},{nz}
StrictNodes 1

# Preferir nós de entrada em países neutros
EntryNodes {ch},{is},{ro},{bg},{md},{rs},{cz},{sk},{si}
NumEntryGuards 3
GuardLifetime 2 months

# ══════════════════════════════════════════════════════════
# STREAM ISOLATION — separar circuitos por app
# ══════════════════════════════════════════════════════════
SocksPort 9100 IsolateDestAddr
SocksPort 9101 IsolateDestAddr IsolateDestPort
SocksPort 9102 IsolateClientAddr IsolateDestAddr IsolateDestPort

# ══════════════════════════════════════════════════════════
# BRIDGES — Descomentartcase Tor esteja bloqueado
