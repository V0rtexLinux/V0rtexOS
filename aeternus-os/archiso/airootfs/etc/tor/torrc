# ══════════════════════════════════════════════════════════
# ONION SERVICES (comentado — ativar se necessário)
# ══════════════════════════════════════════════════════════
# HiddenServiceDir /var/lib/tor/hidden_service/
# HiddenServicePort 80 127.0.0.1:8080
# HiddenServiceVersion 3
# HiddenServiceDirGroupReadable 0

# ══════════════════════════════════════════════════════════
# PERFORMANCE NETWORK
# ══════════════════════════════════════════════════════════
BandwidthRate 10 MB
BandwidthBurst 20 MB
ConnLimit 1000
MaxMemInQueues 256 MB
ServerDNSResolvConfFile /etc/resolv.conf

# ══════════════════════════════════════════════════════════
# SANDBOX (requer kernel com seccomp)
# ══════════════════════════════════════════════════════════
Sandbox 1
